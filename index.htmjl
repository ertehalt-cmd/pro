<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>🎯 Sniper Pro</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}
:root {
  --bg: #03070f;
  --card: #080f20;
  --border: #0d1f3c;
  --accent: #00c8ff;
  --green: #00e87a;
  --red: #ff2d55;
  --yellow: #ffc300;
  --orange: #ff8c00;
  --text: #c5dcff;
  --muted: #3a5a8a;
}
html, body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Cairo', sans-serif;
  min-height: 100dvh;
  overflow-x: hidden;
}
.app {
  position: relative;
  z-index: 1;
  max-width: 430px;
  margin: 0 auto;
  padding: 0 12px 30px;
}
.hdr {
  padding: 14px 0 12px;
  text-align: center;
  border-bottom: 1px solid var(--border);
  margin-bottom: 12px;
}
.chip {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(0,200,255,.07);
  border: 1px solid rgba(0,200,255,.15);
  border-radius: 20px;
  padding: 3px 12px;
  font-size: .58rem;
  letter-spacing: 2px;
  color: var(--accent);
  text-transform: uppercase;
  margin-bottom: 7px;
}
.dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 6px var(--green);
  animation: blink 1.4s ease infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: .25; }
}
h1 {
  font-family: 'Share Tech Mono', monospace;
  font-size: 1.65rem;
  letter-spacing: 3px;
  color: var(--accent);
  text-shadow: 0 0 28px rgba(0,200,255,.45);
}
.hdr-sub {
  font-size: .63rem;
  color: var(--muted);
  margin-top: 2px;
}
.clk-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  margin-top: 7px;
}
.clk {
  font-family: 'Share Tech Mono', monospace;
  font-size: .92rem;
  letter-spacing: 2px;
}
.tz {
  font-size: .52rem;
  color: var(--muted);
  background: var(--card);
  border: 1px solid var(--border);
  padding: 2px 7px;
  border-radius: 8px;
}
.price-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 12px 16px;
  margin-bottom: 11px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.pc-label {
  font-size: .6rem;
  color: var(--muted);
  margin-bottom: 3px;
  letter-spacing: 1px;
}
.pc-price {
  font-family: 'Share Tech Mono', monospace;
  font-size: 1.4rem;
  color: var(--accent);
  font-weight: 700;
  letter-spacing: 2px;
}
.pc-chg {
  font-size: .65rem;
  font-weight: 700;
  margin-top: 2px;
}
.pc-chg.up { color: var(--green); }
.pc-chg.dn { color: var(--red); }
.pc-right { text-align: left; }
.pc-status {
  font-size: .58rem;
  color: var(--muted);
  margin-bottom: 3px;
}
.pc-updated {
  font-family: 'Share Tech Mono', monospace;
  font-size: .65rem;
  color: var(--yellow);
}
.pc-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
  margin-left: 4px;
}
.pc-dot.live {
  background: var(--green);
  box-shadow: 0 0 6px var(--green);
  animation: blink 1.4s ease infinite;
}
.pc-dot.err { background: var(--red); }
.slbl {
  font-size: .57rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 6px;
}
.sess {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 5px;
  margin-bottom: 9px;
}
.s {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 9px;
  padding: 7px 3px 6px;
  text-align: center;
  transition: all .3s;
}
.s.open {
  border-color: rgba(0,232,122,.35);
  background: rgba(0,232,122,.04);
}
.s.best {
  border-color: rgba(255,195,0,.45);
  background: rgba(255,195,0,.05);
  box-shadow: 0 0 12px rgba(255,195,0,.1);
}
.sf { font-size: .88rem; }
.sn {
  font-size: .5rem;
  color: var(--muted);
  margin: 2px 0 3px;
  font-weight: 700;
}
.sp {
  font-size: .48rem;
  font-weight: 700;
  padding: 2px 4px;
  border-radius: 6px;
  display: inline-block;
}
.sp.open {
  background: rgba(0,232,122,.12);
  color: var(--green);
}
.sp.closed {
  background: rgba(13,31,60,.6);
  color: var(--muted);
}
.sp.best {
  background: rgba(255,195,0,.12);
  color: var(--yellow);
}
.ov {
  font-size: .46rem;
  color: var(--orange);
  display: block;
  margin-top: 2px;
}
.mkt {
  border-radius: 10px;
  padding: 8px 12px;
  display: flex;
  align-items: center;
  gap: 9px;
  margin-bottom: 11px;
  border: 1px solid;
  transition: all .3s;
}
.mkt.hot {
  background: rgba(255,195,0,.05);
  border-color: rgba(255,195,0,.22);
}
.mkt.ok {
  background: rgba(0,232,122,.04);
  border-color: rgba(0,232,122,.18);
}
.mkt.off {
  background: rgba(255,45,85,.04);
  border-color: rgba(255,45,85,.15);
}
.mi { font-size: 1.1rem; flex-shrink: 0; }
.mm {
  font-weight: 700;
  font-size: .75rem;
  display: block;
  margin-bottom: 1px;
}
.ms {
  font-size: .6rem;
  color: var(--muted);
}
.blocker {
  background: rgba(255,45,85,.06);
  border: 1px solid rgba(255,45,85,.2);
  border-radius: 12px;
  padding: 14px;
  text-align: center;
  margin-bottom: 11px;
  display: none;
}
.blocker.show { display: block; }
.bl-i { font-size: 1.8rem; margin-bottom: 5px; }
.bl-t {
  color: var(--red);
  font-weight: 700;
  font-size: .85rem;
  margin-bottom: 3px;
}
.bl-s {
  font-size: .67rem;
  color: var(--muted);
  line-height: 1.6;
}
.bl-n {
  color: var(--yellow);
  font-weight: 700;
  font-size: .75rem;
  margin-top: 7px;
}
.tf-row {
  display: flex;
  gap: 6px;
  margin-bottom: 11px;
  justify-content: center;
}
.tf-pill {
  padding: 5px 14px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background: var(--card);
  color: var(--muted);
  font-size: .68rem;
  cursor: pointer;
  transition: all .2s;
  font-family: 'Cairo', sans-serif;
  font-weight: 600;
}
.tf-pill.active {
  border-color: var(--accent);
  color: var(--accent);
  background: rgba(0,200,255,.08);
  box-shadow: 0 0 10px rgba(0,200,255,.15);
}
.btn-analyze {
  width: 100%;
  padding: 14px;
  border: none;
  border-radius: 12px;
  background: linear-gradient(135deg,#0044aa,#00c8ff);
  color: #fff;
  font-family: 'Cairo', sans-serif;
  font-size: .95rem;
  font-weight: 700;
  cursor: pointer;
  letter-spacing: 1px;
  box-shadow: 0 4px 22px rgba(0,200,255,.3);
  transition: all .22s;
  margin-bottom: 11px;
}
.btn-analyze:active { transform: scale(.97); }
.btn-analyze:disabled {
  opacity: .45;
  cursor: not-allowed;
  transform: none;
}
.spin {
  display: inline-block;
  width: 12px;
  height: 12px;
  border: 2px solid rgba(255,255,255,.2);
  border-top-color: #fff;
  border-radius: 50%;
  animation: sp .6s linear infinite;
  vertical-align: middle;
  margin-left: 4px;
}
@keyframes sp { to { transform: rotate(360deg); } }
.sig-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 13px;
  overflow: hidden;
  margin-bottom: 11px;
  transition: all .35s;
}
.sig-card.call {
  border-color: var(--green);
  box-shadow: 0 0 25px rgba(0,232,122,.14);
}
.sig-card.put {
  border-color: var(--red);
  box-shadow: 0 0 25px rgba(255,45,85,.14);
}
.sig-top {
  padding: 18px 16px 14px;
  text-align: center;
  border-bottom: 1px solid var(--border);
}
.sig-pair {
  font-family: 'Share Tech Mono', monospace;
  font-size: .58rem;
  color: var(--muted);
  letter-spacing: 3px;
  margin-bottom: 5px;
}
.sig-arrow {
  font-size: 2.6rem;
  line-height: 1;
  margin-bottom: 2px;
}
.sig-dir {
  font-family: 'Share Tech Mono', monospace;
  font-size: 1.55rem;
  font-weight: 900;
  letter-spacing: 3px;
}
.sig-dir.call {
  color: var(--green);
  text-shadow: 0 0 18px rgba(0,232,122,.45);
}
.sig-dir.put {
  color: var(--red);
  text-shadow: 0 0 18px rgba(255,45,85,.45);
}
.sig-dir.wait { color: var(--muted); }
.sig-str {
  font-size: .7rem;
  font-weight: 700;
  margin-top: 4px;
}
.sc { color: var(--green); }
.wc { color: #66cc99; }
.spu { color: var(--red); }
.wp { color: #cc6677; }
.sw { color: var(--muted); }
.sig-tf {
  display: inline-block;
  margin-top: 6px;
  background: rgba(0,200,255,.07);
  border: 1px solid rgba(0,200,255,.13);
  border-radius: 20px;
  padding: 2px 11px;
  font-size: .63rem;
  color: var(--accent);
  font-family: 'Share Tech Mono', monospace;
}
.sig-sub {
  font-size: .63rem;
  color: var(--muted);
  margin-top: 3px;
}
.conf-sec {
  padding: 11px 16px 3px;
  display: none;
}
.conf-row {
  display: flex;
  justify-content: space-between;
  font-size: .63rem;
  color: var(--muted);
  margin-bottom: 4px;
}
.conf-pct {
  color: var(--accent);
  font-weight: 700;
  font-family: 'Share Tech Mono', monospace;
}
.conf-bar {
  height: 5px;
  border-radius: 3px;
  background: var(--border);
  overflow: hidden;
}
.conf-fill {
  height: 100%;
  border-radius: 3px;
  width: 0;
  transition: width .9s cubic-bezier(.4,0,.2,1);
}
.cfh { background: linear-gradient(90deg,#009944,#00e87a); }
.cfm { background: linear-gradient(90deg,#996600,#ffc300); }
.cfl { background: linear-gradient(90deg,#770022,#ff2d55); }
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  padding: 9px 16px 13px;
}
.tag {
  padding: 2px 8px;
  border-radius: 14px;
  font-size: .6rem;
  font-weight: 700;
  border: 1px solid;
}
.tb {
  background: rgba(0,232,122,.06);
  border-color: rgba(0,232,122,.18);
  color: var(--green);
}
.tr {
  background: rgba(255,45,85,.06);
  border-color: rgba(255,45,85,.18);
  color: var(--red);
}
.tn {
  background: rgba(0,200,255,.06);
  border-color: rgba(0,200,255,.13);
  color: var(--accent);
}
.pat {
  display: none;
  align-items: center;
  gap: 8px;
  background: rgba(255,195,0,.04);
  border: 1px solid rgba(255,195,0,.18);
  border-radius: 9px;
  padding: 8px 12px;
  margin-bottom: 11px;
}
.pat.show { display: flex; }
.pn {
  color: var(--yellow);
  font-weight: 700;
  font-size: .73rem;
}
.pd {
  color: var(--muted);
  font-size: .6rem;
  margin-top: 1px;
}
.timer {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 10px 13px;
  display: flex;
  align-items: center;
  gap: 11px;
  margin-bottom: 11px;
  transition: border-color .3s;
}
.timer.on {
  border-color: rgba(255,195,0,.35);
  box-shadow: 0 0 14px rgba(255,195,0,.1);
}
.tb2 { flex: 1; }
.tl {
  font-size: .57rem;
  color: var(--muted);
  margin-bottom: 2px;
}
.tv2 {
  font-family: 'Share Tech Mono', monospace;
  font-size: 1.08rem;
  color: var(--yellow);
  letter-spacing: 3px;
}
.tbar {
  height: 2px;
  border-radius: 2px;
  background: var(--border);
  margin-top: 4px;
  overflow: hidden;
}
.tfill {
  height: 100%;
  background: linear-gradient(90deg,var(--yellow),var(--orange));
  border-radius: 2px;
  transition: width 1s linear;
}
.ttf {
  text-align: center;
  font-size: .57rem;
  color: var(--muted);
  line-height: 1.5;
}
.ttf span {
  display: block;
  font-family: 'Share Tech Mono', monospace;
  font-size: .72rem;
  color: var(--accent);
}
.chart-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 11px;
  overflow: hidden;
  margin-bottom: 11px;
  height: 300px;
}
.chart-hdr {
  padding: 8px 13px;
  border-bottom: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.chart-lbl { font-size: .6rem; color: var(--muted); }
.chart-pw {
  text-align: left;
  font-family: 'Share Tech Mono', monospace;
}
.chart-p {
  font-size: .88rem;
  color: var(--accent);
}
.chart-chg { font-size: .57rem; }
.cu { color: var(--green); }
.cd { color: var(--red); }
#tradingview-widget { height: 260px; width: 100%; }
.sh {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: .57rem;
  letter-spacing: 1.8px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 7px;
}
.sh::before {
  content: '';
  width: 2px;
  height: 10px;
  background: var(--accent);
  border-radius: 2px;
  box-shadow: 0 0 6px rgba(0,200,255,.4);
}
.ind-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 5px;
  margin-bottom: 11px;
}
.ind {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 8px 4px;
  text-align: center;
  transition: border-color .3s;
}
.ind.bull { border-color: rgba(0,232,122,.25); }
.ind.bear { border-color: rgba(255,45,85,.25); }
.in {
  font-size: .5rem;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .6px;
  margin-bottom: 3px;
}
.iv {
  font-family: 'Share Tech Mono', monospace;
  font-size: .76rem;
  font-weight: 700;
}
.iv.bull { color: var(--green); }
.iv.bear { color: var(--red); }
.iv.neut { color: var(--yellow); }
.is {
  font-size: .5rem;
  color: var(--muted);
  margin-top: 1px;
}
.hist-list {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-bottom: 16px;
}
.hi {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 7px;
  padding: 7px 11px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-right: 3px solid transparent;
}
.hi.call { border-right-color: var(--green); }
.hi.put { border-right-color: var(--red); }
.hd {
  font-family: 'Share Tech Mono', monospace;
  font-weight: 700;
  font-size: .68rem;
}
.hd.call { color: var(--green); }
.hd.put { color: var(--red); }
.hc {
  color: var(--accent);
  font-family: 'Share Tech Mono', monospace;
  font-size: .68rem;
}
.ht { color: var(--orange); font-size: .58rem; }
.hm { color: var(--muted); font-size: .58rem; }
.no-hist {
  text-align: center;
  color: var(--muted);
  padding: 14px;
  font-size: .7rem;
}
footer {
  text-align: center;
  font-size: .57rem;
  color: var(--muted);
  line-height: 2;
  border-top: 1px solid var(--border);
  padding-top: 10px;
  margin-top: 5px;
}
</style>
</head>
<body>
<div class="app">

<div class="hdr">
  <div class="chip"><span class="dot"></span> REAL MARKET • LIVE</div>
  <h1>🎯 SNIPER PRO</h1>
  <div class="hdr-sub">EUR/USD • إشارات حقيقية 100% • Expert Option</div>
  <div class="clk-row">
    <div class="clk" id="clk">--:--:--</div>
    <div class="tz">توقيت السعودية</div>
  </div>
</div>

<div class="price-card">
  <div>
    <div class="pc-label">EUR / USD • سعر حقيقي</div>
    <div class="pc-price" id="pcPrice">جاري...</div>
    <div class="pc-chg" id="pcChg"></div>
  </div>
  <div class="pc-right">
    <div class="pc-status">حالة الاتصال <span class="pc-dot" id="pcDot"></span></div>
    <div class="pc-updated" id="pcUpdated">--:--</div>
  </div>
</div>

<div class="slbl">حالة الأسواق العالمية</div>
<div class="sess" id="sess"></div>
<div class="mkt" id="mkt">
  <div class="mi" id="mi">⏳</div>
  <div><span class="mm" id="mm">جاري التحقق...</span><span class="ms" id="ms"></span></div>
</div>

<div class="blocker" id="blocker">
  <div class="bl-i">🔒</div>
  <div class="bl-t">السوق الحقيقي مغلق</div>
  <div class="bl-s">EUR/USD يتداول فقط في السوق الحقيقي<br>لا تتداول OTC — نتائجها غير موثوقة</div>
  <div class="bl-n" id="blN"></div>
</div>

<div class="tf-row">
  <div class="tf-pill active" onclick="setTF('1',this)">1 دقيقة</div>
  <div class="tf-pill" onclick="setTF('2',this)">2 دقيقة</div>
  <div class="tf-pill" onclick="setTF('5',this)">5 دقائق</div>
</div>

<button class="btn-analyze" id="analyzeBtn" onclick="analyze()">
  🎯 قنّص الآن — تحليل EUR/USD
</button>

<div class="sig-card" id="sigCard">
  <div class="sig-top">
    <div class="sig-pair">EUR / USD • SNIPER PRO • REAL DATA</div>
    <div class="sig-arrow" id="sigArrow">🎯</div>
    <div class="sig-dir wait" id="sigDir">اضغط قنّص</div>
    <div class="sig-str sw" id="sigStr">—</div>
    <div class="sig-tf" id="sigTF" style="display:none">—</div>
    <div class="sig-sub" id="sigSub">سيتم تحليل السوق الحقيقي وإعطاؤك توصية دقيقة</div>
  </div>
  <div class="conf-sec" id="confSec">
    <div class="conf-row"><span>قوة الإشارة</span><span class="conf-pct" id="confPct">0%</span></div>
    <div class="conf-bar"><div class="conf-fill cfh" id="confFill"></div></div>
  </div>
  <div class="tags" id="tags"></div>
</div>

<div class="pat" id="pat">
  <span style="font-size:1rem">🕯️</span>
  <div><div class="pn" id="pn"></div><div class="pd" id="pd"></div></div>
</div>

<div class="timer" id="timer">
  <div style="font-size:1.1rem">⏱</div>
  <div class="tb2">
    <div class="tl">ادخل الصفقة خلال</div>
    <div class="tv2" id="tVal">--:--</div>
    <div class="tbar"><div class="tfill" id="tFill" style="width:0%"></div></div>
  </div>
  <div class="ttf">الإطار<span id="tTF">—</span></div>
</div>

<div class="chart-card">
  <div class="chart-hdr">
    <div class="chart-lbl">EUR/USD • TradingView مباشر</div>
    <div class="chart-pw">
      <div class="chart-chg" id="chartChg"></div>
      <div class="chart-p" id="chartP">--</div>
    </div>
  </div>
  <div id="tradingview-widget"></div>
</div>

<div class="sh">المؤشرات الفنية — بيانات حقيقية</div>
<div class="ind-grid">
  <div class="ind" id="ci-rsi"><div class="in">RSI 14</div><div class="iv neut" id="vi-rsi">--</div><div class="is" id="si-rsi">--</div></div>
  <div class="ind" id="ci-macd"><div class="in">MACD</div><div class="iv neut" id="vi-macd">--</div><div class="is" id="si-macd">--</div></div>
  <div class="ind" id="ci-stoch"><div class="in">Stoch</div><div class="iv neut" id="vi-stoch">--</div><div class="is" id="si-stoch">--</div></div>
  <div class="ind" id="ci-ema9"><div class="in">EMA 9</div><div class="iv neut" id="vi-ema9">--</div><div class="is" id="si-ema9">--</div></div>
  <div class="ind" id="ci-ema21"><div class="in">EMA 21</div><div class="iv neut" id="vi-ema21">--</div><div class="is" id="si-ema21">--</div></div>
  <div class="ind" id="ci-bb"><div class="in">BB %</div><div class="iv neut" id="vi-bb">--</div><div class="is" id="si-bb">--</div></div>
</div>

<div class="sh">آخر التوصيات</div>
<div id="hist"><div class="no-hist">اضغط قنّص لبدء الإشارات 🎯</div></div>

<footer>Sniper Pro • EUR/USD • بيانات حقيقية 100%<br>ريد ون 🔴 × عتيق • التداول ينطوي على مخاطر</footer>
</div>

<script type="text/javascript" src="https://s3.tradingview.com/tv.js"></script>
<script>
new TradingView.widget({
  "width": "100%",
  "height": 260,
  "symbol": "FX:EURUSD",
  "interval": "1",
  "timezone": "Etc/UTC",
  "theme": "dark",
  "style": "1",
  "locale": "ar",
  "toolbar_bg": "#f1f3f6",
  "enable_publishing": false,
  "hide_top_toolbar": true,
  "hide_legend": true,
  "save_image": false,
  "container_id": "tradingview-widget"
});
</script>

<script>
const API_KEY = 'a16e72269b854e348b1adc5a3e8c3387';
let candles = [];
let currentTF = '1';
let timerInt = null;
let histArr = [];

async function fetchPrices() {
  const map = {'1':'1min','2':'2min','5':'5min'};
  try {
    const r = await fetch(`https://api.twelvedata.com/time_series?symbol=EUR/USD&interval=${map[currentTF]}&outputsize=120&apikey=${API_KEY}`);
    const d = await r.json();
    if (!d.values) { setConnErr(); return false; }
    candles = d.values.reverse().map(v=>({o:+v.open,h:+v.high,l:+v.low,c:+v.close}));
    const last = candles[candles.length-1];
    const prev = candles[candles.length-10]||candles[0];
    const chg = ((last.c-prev.c)/prev.c*100);
    document.getElementById('pcPrice').textContent = last.c.toFixed(5);
    const ce = document.getElementById('pcChg');
    ce.textContent = (chg>=0?'▲ +':'▼ ')+chg.toFixed(4)+'%';
    ce.className = 'pc-chg '+(chg>=0?'up':'dn');
    document.getElementById('pcDot').className = 'pc-dot live';
    document.getElementById('pcUpdated').textContent = new Date().toLocaleTimeString('ar',{hour:'2-digit',minute:'2-digit'});
    updateChartPrice(); 
    return true;
  } catch(e) { setConnErr(); return false; }
}

function setConnErr() {
  document.getElementById('pcDot').className = 'pc-dot err';
  document.getElementById('pcUpdated').textContent = 'خطأ';
}

const SD=[
  {n:'سيدني',f:'🇦🇺',o:21,c:6,w:true},
  {n:'طوكيو',f:'🇯🇵',o:0,c:9,w:false},
  {n:'لندن',f:'🇬🇧',o:7,c:16,w:false},
  {n:'نيويورك',f:'🇺🇸',o:12,c:21,w:false},
];

function isOpen(s,h,m){
  const n=h*60+m;
  if(s.w){
    const a=n<s.o*60?n+1440:n;
    return a>=s.o*60&&a<s.c*60+1440;
  }
  return n>=s.o*60&&n<s.c*60;
}

function realOpen(){
  const n=new Date(),d=n.getUTCDay(),h=n.getUTCHours(),m=n.getUTCMinutes();
  if(d===0||d===6||(d===5&&h>=21))return false;
  return isOpen(SD[2],h,m)||isOpen(SD[3],h,m);
}

function nextOpen(){
  const n=new Date(),d=n.getUTCDay(),h=n.getUTCHours();
  if(d===0||d===6||(d===5&&h>=21))return'السوق يفتح الاثنين 10:00 ص';
  if(h<7)return'لندن تفتح 10:00 ص (توقيت السعودية)';
  return'نيويورك مفتوحة حتى 00:00';
}

function renderSessions(){
  const n=new Date(),h=n.getUTCHours(),m=n.getUTCMinutes(),ov=h*60+m>=12*60&&h*60+m<16*60;
  document.getElementById('sess').innerHTML=SD.map(s=>{
    const op=isOpen(s,h,m),best=op&&(s.n==='لندن'||s.n==='نيويورك')&&ov;
    const cls=best?'best':op?'open':'';
    const pt=best?'⭐ BEST':op?'مفتوح':'مغلق';
    const pc=best?'best':op?'open':'closed';
    return`<div class="s ${cls}"><div class="sf">${s.f}</div><div class="sn">${s.n}</div><span class="sp ${pc}">${pt}</span>${best?'<span class="ov">تداخل ⚡</span>':''}</div>`;
  }).join('');
  
  const lon=isOpen(SD[2],h,m),ny=isOpen(SD[3],h,m),ro=realOpen();
  const b=document.getElementById('mkt');
  
  if(ov&&lon&&ny){
    b.className='mkt hot';
    document.getElementById('mi').textContent='🔥';
    document.getElementById('mm').textContent='🔥 تداخل لندن × نيويورك — أفضل وقت';
    document.getElementById('ms').textContent='أعلى سيولة • إشارات أقوى وأدق';
  } else if(lon&&ro){
    b.className='mkt ok';
    document.getElementById('mi').textContent='✅';
    document.getElementById('mm').textContent='جلسة لندن مفتوحة — وقت جيد';
    document.getElementById('ms').textContent='EUR/USD نشط — إشارات موثوقة';
  } else if(ny&&ro){
    b.className='mkt ok';
    document.getElementById('mi').textContent='✅';
    document.getElementById('mm').textContent='جلسة نيويورك مفتوحة';
    document.getElementById('ms').textContent='حركة جيدة على EUR/USD';
  } else {
    b.className='mkt off';
    document.getElementById('mi').textContent='⛔';
    document.getElementById('mm').textContent='السوق الحقيقي مغلق';
    document.getElementById('ms').textContent='انتظر جلسة لندن أو نيويورك';
  }
  
  const blk=document.getElementById('blocker'),btn=document.getElementById('analyzeBtn');
  if(!ro){
    blk.classList.add('show');
    btn.disabled=true;
    document.getElementById('blN').textContent=nextOpen();
  } else {
    blk.classList.remove('show');
    btn.disabled=false;
  }
}

function setTF(tf,el){
  currentTF=tf;
  document.querySelectorAll('.tf-pill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  fetchPrices();
}

const I={
  ema(a,p){
    if(a.length<p)return a[a.length-1]||0;
    const k=2/(p+1);
    let e=a.slice(0,p).reduce((x,y)=>x+y)/p;
    for(let i=p;i<a.length;i++)e=a[i]*k+e*(1-k);
    return+e.toFixed(5);
  },
  rsi(a,p=14){
    if(a.length<p+1)return 50;
    let g=0,l=0;
    for(let i=a.length-p;i<a.length;i++){
      const d=a[i]-a[i-1];
      d>0?g+=d:l-=d;
    }
    return+(100-100/(1+g/p/(l/p||1e-9))).toFixed(2);
  },
  macd(a){
    return+(this.ema(a,12)-this.ema(a,26)).toFixed(6);
  },
  stoch(c,p=14){
    if(c.length<p)return 50;
    const s=c.slice(-p),hh=Math.max(...s.map(x=>x.h)),ll=Math.min(...s.map(x=>x.l));
    return+((c[c.length-1].c-ll)/(hh-ll||1e-9)*100).toFixed(2);
  },
  bb(a,p=20){
    if(a.length<p)return 0.5;
    const s=a.slice(-p),m=s.reduce((x,y)=>x+y)/p;
    const sd=Math.sqrt(s.map(x=>(x-m)**2).reduce((x,y)=>x+y)/p);
    const cur=a[a.length-1];
    return+((cur-(m-2*sd))/(4*sd||1e-9)).toFixed(3);
  }
};

function getPattern(c){
  if(c.length<3)return null;
  const[c2,c1,c0]=c.slice(-3);
  const bd=x=>Math.abs(x.c-x.o),rn=x=>x.h-x.l||1e-9,bu=x=>x.c>x.o,be=x=>x.c<x.o,dj=x=>bd(x)/rn(x)<0.12;
  const lw=x=>Math.min(x.o,x.c)-x.l,uw=x=>x.h-Math.max(x.o,x.c);
  
  if(dj(c0))return{n:'دوجي',d:bu(c1)?'PUT':'CALL',ds:'تردد السوق — انعكاس محتمل',s:2};
  if(be(c1)&&bu(c0)&&c0.o<c1.c&&c0.c>c1.o)return{n:'ابتلاع صعودي',d:'CALL',ds:'انعكاس صعودي قوي ✅',s:3};
  if(bu(c1)&&be(c0)&&c0.o>c1.c&&c0.c<c1.o)return{n:'ابتلاع هبوطي',d:'PUT',ds:'انعكاس هبوطي قوي ✅',s:3};
  if(bu(c0)&&lw(c0)>bd(c0)*1.8&&uw(c0)<bd(c0)*0.4)return{n:'مطرقة 🔨',d:'CALL',ds:'ارتداد من الدعم',s:3};
  if(be(c0)&&uw(c0)>bd(c0)*1.8&&lw(c0)<bd(c0)*0.4)return{n:'نجمة هاوية ⭐',d:'PUT',ds:'رفض المقاومة',s:3};
  if(bu(c2)&&bu(c1)&&bu(c0)&&c0.c>c1.c&&c1.c>c2.c)return{n:'3 جنود بيض',d:'CALL',ds:'زخم صاعد قوي 🚀',s:4};
  if(be(c2)&&be(c1)&&be(c0)&&c0.c<c1.c&&c1.c<c2.c)return{n:'3 غربان سود',d:'PUT',ds:'زخم هابط قوي 📉',s:4};
  if(be(c2)&&dj(c1)&&bu(c0)&&c0.c>(c2.o+c2.c)/2)return{n:'نجمة الصباح',d:'CALL',ds:'انعكاس صعودي مؤكد ✅',s:4};
  if(bu(c2)&&dj(c1)&&be(c0)&&c0.c<(c2.o+c2.c)/2)return{n:'نجمة المساء',d:'PUT',ds:'انعكاس هبوطي مؤكد ✅',s:4};
  return null;
}

function strategy(){
  if(candles.length<30)return null;
  const cl=candles.map(x=>x.c),rsi=I.rsi(cl),macdV=I.macd(cl),stoch=I.stoch(candles),e9=I.ema(cl,9),e21=I.ema(cl,21),bbV=I.bb(cl);
  const l5=cl.slice(-5),tr=l5[4]>l5[0]?'up':l5[4]<l5[0]?'down':'flat';
  const pat=getPattern(candles);
  let cs=0,ps=0,cr=[],pr=[];
  
  if(rsi<25){cs+=4;cr.push({t:`RSI ${rsi} ذروة بيع حاد`,c:'tb'})}
  else if(rsi<35){cs+=2;cr.push({t:`RSI ${rsi} ذروة بيع`,c:'tb'})}
  else if(rsi<42){cs+=1;cr.push({t:`RSI ${rsi} دعم`,c:'tb'})}
  else if(rsi>75){ps+=4;pr.push({t:`RSI ${rsi} ذروة شراء حاد`,c:'tr'})}
  else if(rsi>65){ps+=2;pr.push({t:`RSI ${rsi} ذروة شراء`,c:'tr'})}
  else if(rsi>58){ps+=1;pr.push({t:`RSI ${rsi} مقاومة`,c:'tr'})}
  
  if(macdV>0.00012){cs+=3;cr.push({t:'MACD قوي ↑',c:'tb'})}
  else if(macdV>0.00004){cs+=1;cr.push({t:'MACD إيجابي',c:'tb'})}
  else if(macdV<-0.00012){ps+=3;pr.push({t:'MACD قوي ↓',c:'tr'})}
  else if(macdV<-0.00004){ps+=1;pr.push({t:'MACD سلبي',c:'tr'})}
  
  if(stoch<15){cs+=3;cr.push({t:`Stoch ${stoch} بيع مفرط`,c:'tb'})}
  else if(stoch<30){cs+=1;cr.push({t:`Stoch ${stoch} دعم`,c:'tb'})}
  else if(stoch>85){ps+=3;pr.push({t:`Stoch ${stoch} شراء مفرط`,c:'tr'})}
  else if(stoch>70){ps+=1;pr.push({t:`Stoch ${stoch} مقاومة`,c:'tr'})}
  
  const ed=e9-e21;
  if(ed>0.0004){cs+=3;cr.push({t:'EMA9 فوق EMA21 بقوة',c:'tb'})}
  else if(ed>0.0001){cs+=1;cr.push({t:'EMA تقاطع صاعد',c:'tb'})}
  else if(ed<-0.0004){ps+=3;pr.push({t:'EMA9 تحت EMA21 بقوة',c:'tr'})}
  else if(ed<-0.0001){ps+=1;pr.push({t:'EMA تقاطع هابط',c:'tr'})}
  
  if(bbV<0.08){cs+=3;cr.push({t:'BB حد سفلي — ارتداد',c:'tb'})}
  else if(bbV<0.22){cs+=1;cr.push({t:'BB منطقة شراء',c:'tb'})}
  else if(bbV>0.92){ps+=3;pr.push({t:'BB حد علوي — رفض',c:'tr'})}
  else if(bbV>0.78){ps+=1;pr.push({t:'BB منطقة بيع',c:'tr'})}
  
  if(tr==='up'){cs+=1;cr.push({t:'اتجاه صاعد',c:'tb'})}
  if(tr==='down'){ps+=1;pr.push({t:'اتجاه هابط',c:'tr'})}
  
  if(pat){
    if(pat.d==='CALL'){cs+=pat.s;cr.push({t:`🕯️ ${pat.n}`,c:'tb'})}
    else{ps+=pat.s;pr.push({t:`🕯️ ${pat.n}`,c:'tr'})}
  }
  
  const tfSec=currentTF==='1'?60:currentTF==='2'?120:300;
  const tfL=currentTF==='1'?'1 دقيقة ⚡':currentTF==='2'?'2 دقيقة':'5 دقائق';
  const mx=19;
  
  if(cs>=6&&cs>ps+2){
    const conf=Math.min(96,Math.round(56+(cs/mx)*41));
    const st=cs>=14?'🔥 شراء قوي جداً':cs>=9?'✅ شراء قوي':'شراء محتمل';
    return{dir:'CALL',conf,reasons:cr.slice(0,5),tf:tfSec,tfL,st,sc:cs>=12?'sc':'wc',pat,rsi,macdV,stoch,e9,e21,bbV};
  }
  if(ps>=6&&ps>cs+2){
    const conf=Math.min(96,Math.round(56+(ps/mx)*41));
    const st=ps>=14?'🔥 بيع قوي جداً':ps>=9
